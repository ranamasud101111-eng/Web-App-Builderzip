# ── Required in production ────────────────────────────────────────────────────

# PostgreSQL connection string (from Supabase: Settings > Database > URI)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign JWT tokens — use a long random string (min 32 chars)
JWT_SECRET=replace_with_a_long_random_secret_string

# ── Recommended in production ─────────────────────────────────────────────────

# Set to "production" on Render — enables SSL for DB and strict CORS
NODE_ENV=production

# Comma-separated list of frontend origins allowed to call this API
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# ── Optional ──────────────────────────────────────────────────────────────────

# Render sets PORT automatically — only set this locally if needed
# PORT=3001
