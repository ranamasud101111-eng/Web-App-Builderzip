modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash /home/runner/workspace/start.sh"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd /home/runner/workspace/server && node src/index.js & cd /home/runner/workspace/client && npx vite build --outDir ../dist && cd /home/runner/workspace && npx serve dist -p 5000 -s"]

[userenv]

[userenv.shared]
FRONTEND_URL = "https://a8e3e8f4-dc8d-4f99-a821-512047cb2853-00-1e52iisgsit16.sisko.replit.dev"
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
